{
  "name": "fleettodo",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "node -e \"process.env.EXPO_HOME=require('path').join(process.cwd(),'.expo-home');require('child_process').spawn('npx',['expo','start','--lan','--clear'],{stdio:'inherit',shell:true});\"",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android": "cross-env NODE_ENV=production npx expo run:android --variant release --no-install"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "convex": "^1.32.0",
    "expo": "^55.0.7",
    "expo-constants": "~55.0.7",
    "expo-document-picker": "~55.0.8",
    "expo-font": "~55.0.4",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.5",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "react": "19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.2"
  },
  "private": true,
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.2.10",
    "cross-env": "^10.1.0",
    "typescript": "~5.9.2"
  }
}
